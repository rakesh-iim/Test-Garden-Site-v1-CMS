PORT=5000
USE_IN_MEMORY_DB=false
MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/mrgardenr_cms?retryWrites=true&w=majority
JWT_SECRET=replace-with-a-random-secret-at-least-32-characters
JWT_EXPIRES_IN=90d
CORS_ORIGIN=http://localhost:5173

# Used only by `npm run seed:admin`
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-password

# Used only when `USE_IN_MEMORY_DB=true`
DEV_ADMIN_NAME=Admin
DEV_ADMIN_EMAIL=admin@example.com
DEV_ADMIN_PASSWORD=change-this-password
